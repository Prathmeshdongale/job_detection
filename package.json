{
  "name": "job-fraud-detection",
  "version": "1.0.0",
  "description": "Job Fraud Detection Platform — monorepo root",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "server": "npm run dev --workspace=server",
    "client": "npm run dev --workspace=client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "test:server": "npm test --workspace=server",
    "test:client": "npm test --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
